  "identifier": "SB2123",
  "title": "AN ACT RELATING TO TAXATION -- PROPERTY SUBJECT TO TAXATION",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Exempts from taxation the real and tangible personal property of Blackstone Valley Advocacy Center located in the city of Pawtucket. Effective retroactively to December 31, 2025 and affects next levy issued by the city or town where property is located."
    }
  ],
