    "resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Amends the constitution to guarantee Rhode Island residents with equal opportunity to receive an education that is adequate, equitable and meaningful and provides judicial enforcement of this provision."
    }
