  "abstracts": [
    {
      "note": "summary",
      "abstract": "Eliminates the \"until June 30, 2026\" sunset on the increase in the total amount of earnings a partial-unemployment insurance claimant can receive before being entirely disqualified for unemployment insurance benefits."
    }
