  "identifier": "SB3116",
  "title": "AN ACT RELATING TO STATE AFFAIRS AND GOVERNMENT -- RESTRICTIONS ON STATE AND MUNICIPAL COOPERATION WITH CIVIL IMMIGRATION ENFORCEMENT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits state or local authorities from voluntary participation in federal civil immigration enforcement. It would not prohibit compliance with a judicial warrant or court order issued by a court of competent jurisdiction."
    }
  ],
