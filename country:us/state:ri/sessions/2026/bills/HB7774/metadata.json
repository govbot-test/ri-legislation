  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Amends the state building code and would require that the state adopt the 2024 International Residential Code and prohibit the state building committee from adopting amendments for one to four residential dwelling units until 2030."
    }
  ],
