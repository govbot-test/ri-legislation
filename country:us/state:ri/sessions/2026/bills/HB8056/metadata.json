  "identifier": "HB8056",
  "title": "AN ACT RELATING TO CRIMINAL OFFENSES -- CHILDREN",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires courts and bail commissioners to issue no contact orders against any person arrested for cruelty or neglect of a child, child abuse or child endangerment and to issue orders upon any finding of guilty. Violations of order would be a misdemeanor."
    }
  ],
