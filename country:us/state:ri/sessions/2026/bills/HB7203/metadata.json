  "identifier": "HB7203",
  "title": "AN ACT RELATING TO CRIMINAL PROCEDURE -- BAIL AND RECOGNIZANCE",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits the courts from setting cash or surety bail on any misdemeanor offense but permits the court to set reasonable non-monetary conditions of bail to assure the defendant's presence in court as required and to protect the community."
    }
  ],
