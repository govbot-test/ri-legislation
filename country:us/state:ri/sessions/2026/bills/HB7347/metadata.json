  "identifier": "HB7347",
  "title": "AN ACT RELATING TO INSURANCE -- ACCIDENT AND SICKNESS INSURANCE POLICIES",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Limits prior authorization requirements for rehabilitative and habilitative services. Also prohibits prior authorization for the first twelve (12) visits of a new episode of care and for ninety (90) days following a chronic pain diagnosis."
    }
