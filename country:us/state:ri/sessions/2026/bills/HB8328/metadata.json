  "identifier": "HB8328",
  "title": "AN ACT RELATING TO COURTS AND CIVIL PROCEDURE -- COURTS -- PERMITTING VIRTUAL OR REMOTE COURT HEARINGS",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Permits all Rhode Island courts to conduct hearings remotely and allow any party or attorney to appear by telephone or video conference, with remote appearances having the same legal effect as in-person appearances."
    }
