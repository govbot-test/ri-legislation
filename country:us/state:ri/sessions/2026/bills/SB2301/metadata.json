  "identifier": "SB2301",
  "title": "AN ACT RELATING TO INSURANCE -- UNFAIR CLAIMS SETTLEMENT PRACTICES ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Amends unfair claims practices law by requiring an insurance appraisal by a licensed appraiser where damage to a motor vehicle exceeds $5,000 (from $2,500) and eliminates language that prohibits an appraisal based on photos of a damaged motor vehicle."
    }
  ],
