  "abstracts": [
    {
      "note": "summary",
      "abstract": "Limits municipal minimum lot sizes for residential use to 2,500 sq ft near transit, 5,000 sq. ft with water/sewer, and 1 acre otherwise, while protecting farmlands, forests, and wetlands, and requiring zoning updates to comply."
