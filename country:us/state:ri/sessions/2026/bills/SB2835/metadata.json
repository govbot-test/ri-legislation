  "abstracts": [
    {
      "note": "summary",
      "abstract": "Changes the teacher and state employees' retirement benefit calculations' cutoff date from July 1, 2024, to July 1, 2012, for all retirement members eligible to and who retire on or after the new July 1, 2012, cutoff date."
