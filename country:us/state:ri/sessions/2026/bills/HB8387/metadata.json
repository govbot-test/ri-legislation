  "identifier": "HB8387",
  "title": "AN ACT RELATING TO TOWNS AND CITIES -- ZONING ORDINANCES",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires all municipal zoning ordinances be amended to provide that any lot with access to public water/sewer services, not establish or enforce a minimum lot area that exceeds 5,000 sq.ft. for a residential building with between one and 4 dwelling units."
    }
  ],
