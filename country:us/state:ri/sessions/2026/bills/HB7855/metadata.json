  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Defines a special assessment as an assessment that is not a part of the condominium association budget and would apply to condominiums created before July 1, 1982, but only apply with respect to events and circumstances occurring after that date."
    }
