  "identifier": "HR7367",
  "title": "HOUSE RESOLUTION CREATING A SPECIAL LEGISLATIVE COMMISSION TO STUDY AND PROVIDE RECOMMENDATIONS TO REDUCE THE FORTY-HOUR WORKWEEK TO A THIRTY-TWO-HOUR WORKWEEK",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Creates a 9-member commission to study and provide recommendations to reduce the forty-hour workweek to a thirty-two-hour workweek, and would report back to the House by March 15, 2027, and would expire on June 15, 2027."
    }
  ],
