  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows foreign-trained dentists and dental hygienists to obtain limited licenses if they graduate from reputable dental colleges or universities, work under a supervising dentist, and pass a board-approved exam."
    }
