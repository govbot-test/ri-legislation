  "title": "AN ACT RELATING TO COMMERCIAL LAW--GENERAL REGULATORY PROVISIONS -- ARTIFICIAL INTELLIGENCE COMPANION MODELS",
  "from_organization": "~{\"classification\": \"lower\"}",
