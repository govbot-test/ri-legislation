  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires effective January 1, 2027, that upon the execution of a lease agreement for a mobile and manufactured homes in a mobile and manufactured home park, a complete copy of the lease be provided to the tenant within 10 days of execution."
    }
