{
  "legislative_session": "2026",
  "identifier": "SB3113",
  "title": "AN ACT RELATING TO ELECTIONS -- CONDUCT OF ELECTION AND VOTING EQUIPMENT, AND SUPPLIES",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Increases from seven (7) days to nine (9) days the period of time in which a request for a recount of the votes cast can be made to the board of elections. No certificates of election may be issued, until the recount if any is completed."
    }
  ],
