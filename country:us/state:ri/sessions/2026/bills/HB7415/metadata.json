  "identifier": "HB7415",
  "title": "AN ACT RELATING TO EDUCATION -- ESTABLISHMENT OF CHARTER PUBLIC SCHOOLS",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Bars the council from granting approval to create or expand a charter school beginning operations in 26-27 school year and bars the state from approving or appropriating funds to a new charter school not approved before July 1, 2025."
    }
  ],
