  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Limits rent increases to no more than 4% annually unless the landlord is granted an exemption by secretary of housing, and provides tenants with civil action to recover damages, including award of attorneys' fees and punitive damages, for any violations."
