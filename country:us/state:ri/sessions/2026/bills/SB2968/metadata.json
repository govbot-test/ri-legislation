  "identifier": "SB2968",
  "title": "AN ACT RELATING TO COMMERCIAL LAW -- GENERAL REGULATORY PROVISIONS -- RHODE ISLAND SOCIAL MEDIA REGULATION ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
