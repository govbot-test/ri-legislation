  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Creates the Rhode Island Social Media Regulation act, which would not permit a Rhode Island resident who is a minor to be an account holder on a social media's platform unless the minor has the express consent of a parent or guardian."
    }
  ],
