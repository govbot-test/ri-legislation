  "identifier": "HB7310",
  "title": "AN ACT RELATING TO STATE AFFAIRS AND GOVERNMENT -- HEALTH CARE FOR CHILDREN AND PREGNANT WOMEN",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires EOHHS to provide self-measured blood pressure monitoring for eligible pregnant and postpartum individuals, covering home monitors, training, data transmission, and co-interventions, with state funds if federal aid is unavailable."
    }
  ],
