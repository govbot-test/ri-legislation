  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Reinstates general revenue sharing of state aid among the 39 cities and towns in Rhode Island. The initial amount is based upon population, and increased annually thereafter based on the increase in the Consumer Price Index for all Urban Consumers."
    }
