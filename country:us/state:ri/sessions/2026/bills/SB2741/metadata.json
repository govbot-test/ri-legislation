  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows retired teachers, state and municipal workers to be employed without the loss of any retirement benefits, as long as they reside in Rhode Island at least 270 days and have an annual income from all sources that is less than $55,000."
