  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Increases the minimum hourly wage commencing January 1, 2029, by an amount equal to the total percentage increase in the Consumer Price Index for all Urban Consumers (CPI-U) for the Northeast Region for the calendar year 2027."
    }
