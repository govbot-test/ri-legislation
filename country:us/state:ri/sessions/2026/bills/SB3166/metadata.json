  "identifier": "SB3166",
  "title": "AN ACT RELATING TO HIGHWAYS -- RHODE ISLAND TURNPIKE AND BRIDGE AUTHORITY",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Provides that motor vehicle rental companies be entitled to establish non-liability for toll violations, administrative fees, registration penalties, and fines by providing a rental or lease agreement as prima facie evidence against a lessee."
    }
  ],
