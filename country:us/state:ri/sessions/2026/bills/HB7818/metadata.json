  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits family court from detaining or committing any youth, 12 years or younger, to training school, for any offense other than murder, first degree sexual assault, or an attempt to commit such offenses there is no other reasonable placement."
