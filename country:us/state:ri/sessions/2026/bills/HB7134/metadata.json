  "abstracts": [
    {
      "note": "summary",
      "abstract": "Establishes Rhode Island First Step program requiring DOC to assist offenders with reintegration into society, counseling, medical care, education, early sentence termination or pre-release confinement for elderly and terminally ill offenders."
