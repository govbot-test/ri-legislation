  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires pharmacy benefit managers to apply for certificate of authority from DBR to operate such a business in this state. Empowers the health insurance commissioner to oversee pharmacy benefit managers and penalize violations."
    }
