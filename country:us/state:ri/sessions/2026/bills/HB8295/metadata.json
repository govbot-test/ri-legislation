  "identifier": "HB8295",
  "title": "AN ACT RELATING TO TAXATION -- PROPERTY SUBJECT TO TAXATION -- VETERANS' EXEMPTIONS -- TOWN OF EXETER",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Creates an exemption from property taxes in the amount of $5,000 for any veteran of the military or naval service of the United States who is to be totally disabled through a service-connected disability in the town of Exeter."
    }
  ],
