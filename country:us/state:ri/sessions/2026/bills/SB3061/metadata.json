  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires healthcare insurers, without prior authorization, to provide post-acute care services to patients discharged from a hospital for a minimum of seven (7) days commencing on or after January 1, 2027."
    }
