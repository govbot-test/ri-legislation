  "identifier": "HB7432",
  "title": "AN ACT RELATING TO CRIMINAL PROCEDURE -- INDICTMENTS, INFORMATIONS AND COMPLAINTS",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
