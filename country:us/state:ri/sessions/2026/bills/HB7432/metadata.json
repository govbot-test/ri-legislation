  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits prosecutions for crimes in Rhode Island if the prosecution arises from the same facts or acts for which the defendant was acquitted in another jurisdiction, unless newly discovered evidence substantially warrants prosecution."
    }
