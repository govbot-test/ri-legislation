  "abstracts": [
    {
      "note": "summary",
      "abstract": "Authorizes the secretary of the executive office of health and human services (EOHHS) to increase resource eligibility limits for persons with long-term care needs who reside at home to $12,000 for single persons and $18,000 for couples."
