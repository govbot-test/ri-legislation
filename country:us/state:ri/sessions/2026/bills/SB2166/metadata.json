  "identifier": "SB2166",
  "title": "AN ACT RELATING TO LABOR AND LABOR RELATIONS -- MINIMUM WAGES--OVERTIME",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires small employers with one to fifty (1-50) employees and large employers with fifty (50) or more employees to pay overtime wages to exempt workers if their salary exceeds varying multipliers of minimum wage for a forty (40) hour workweek."
    }
  ],
