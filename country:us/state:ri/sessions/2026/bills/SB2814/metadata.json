  "abstracts": [
    {
      "note": "summary",
      "abstract": "Removes the requirement that 5% of the hotel tax generated from regional tourism districts be paid to the Greater Providence-Warwick Convention and Visitors Bureau, and adds that 5% of the hotel tax to the existing tax paid to the RI commerce corporation."
    }
