  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires that applicants for a retail liquor license in the town of Westerly acquire commercial, general-liability, liquor liability and property damage insurance coverage in the amount of three hundred thousand dollars ($300,000)."
    }
