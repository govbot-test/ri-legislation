  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits force-feeding to create a force-fed poultry product or the hiring of another to engage in force-feeding of a poultry product. It also prohibits the sale of a force-fed poultry product or food containing a force-fed poultry product."
    }
