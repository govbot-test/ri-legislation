{
  "legislative_session": "2026",
  "identifier": "SB2291",
  "title": "AN ACT RELATING TO PROPERTY -- RESIDENTIAL LANDLORD AND TENANT ACT -- RHODE ISLAND SURVIVOR EARLY LEASE TERMINATION ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Grants tenants that are the victim of various forms of abuse including, but not limited to, sexual and domestic abuse and stalking, the right to terminate a lease agreement early without penalty or liability for rent. Effective 7/1/26."
    }
  ],
