  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Authorizes the state retirement board to revoke or reduce an individual\u2019s pension benefit if that individual is convicted or pleads guilty or no contest to a felony sex crime related to their public office or public employment."
    }
