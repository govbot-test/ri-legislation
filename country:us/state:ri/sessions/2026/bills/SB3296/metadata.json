  "title": "AN ACT RELATING TO PUBLIC OFFICERS AND EMPLOYEES -- RHODE ISLAND PUBLIC EMPLOYEE PENSION REVOCATION AND REDUCTION ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
