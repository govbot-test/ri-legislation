  "title": "HOUSE RESOLUTION CREATING A SPECIAL LEGISLATIVE COMMISSION TO STUDY AND PROVIDE RECOMMENDATIONS ON THE WATER SUPPLY PLANNING FOR NEW HOUSING DEVELOPMENTS IN RURAL COMMUNITIES",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Creates a special legislative commission to study/provide recommendations for water supply planning for new housing developments in rural communities, whose findings/recommendations to the House of Representatives on or before 6/15/27 and expires 7/1/27."
    }
  ],
