  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits those people convicted of sex offenses from living within proximity to their victim's residences, workplaces or schools and automatically be prohibited from having any direct or indirect contact with the victim(s)."
