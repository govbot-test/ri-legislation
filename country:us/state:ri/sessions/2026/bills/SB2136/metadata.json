  "identifier": "SB2136",
  "title": "AN ACT RELATING TO ELECTIONS -- LOCAL CANVASSING AUTHORITIES",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires party chairpersons to submit lists of party voters to the mayor or council president within 30 days of notice of vacancy in a municipal election office and mayor/council president are required to make a replacement nomination within 30 days."
    }
  ],
