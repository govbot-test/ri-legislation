  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Provides that the EOHHS, through Emergency Medicaid, cover dialysis for the treatment of end stage renal disease (\"ESRD\") and kidney transplants for RI residents who do not qualify for full Medicaid under federal law due to their immigration status."
    }
