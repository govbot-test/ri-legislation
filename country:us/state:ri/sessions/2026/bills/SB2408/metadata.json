  "identifier": "SB2408",
  "title": "AN ACT RELATING TO LABOR AND LABOR RELATIONS -- MINIMUM WAGES",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Commencing January 1, 2027, this act would increase the minimum wage for employees receiving gratuities, from the current three dollars and eighty-nine cents ($3.89) to six dollars and seventy-five cents ($6.75) per hour."
    }
  ],
