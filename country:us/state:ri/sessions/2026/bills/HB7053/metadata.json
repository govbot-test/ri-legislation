  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Amends the current law on teacher\u2019s creditable service so that a teacher who takes an unpaid parental or medical leave during the year would be given credit for a year of service for that school year if they served a minimum of 135 school days."
    }
