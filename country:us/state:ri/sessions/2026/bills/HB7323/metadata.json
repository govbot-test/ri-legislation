  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires every individual or group health insurance contract effective on or after January 1, 2027, to provide coverage to the insured and the insured's spouse and dependents for all FDA-approved contraceptive drugs, devices and other products."
    }
