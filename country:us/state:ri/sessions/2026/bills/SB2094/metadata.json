  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires any remaining funds in the enacted budget from the RI promise scholarship program or the RI hope scholarship program, after Rhode Island college has satisfied all eligible scholarships to be reimbursed to onward we learn."
