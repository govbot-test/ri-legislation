  "identifier": "SB2488",
  "title": "AN ACT RELATING TO STATE AFFAIRS AND GOVERNMENT -- BAIL BOND AGENTS AND BAIL BOND RECOVERY AGENTS",
  "from_organization": "~{\"classification\": \"upper\"}",
