  "abstracts": [
    {
      "note": "summary",
      "abstract": "Mandates that athletic teams that are sponsored by a public school or a private school whose teams compete against a public school, be designated as (1) \"males\", \"men\" or \"boys\"; (2) \"females\", \"women\" or \"girls\"; or (3) \"coed\" or \"mixed\"."
    }
