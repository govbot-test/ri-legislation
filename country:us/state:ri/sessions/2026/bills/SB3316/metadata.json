  "legislative_session": "2026",
  "identifier": "SB3316",
  "title": "AN ACT REGARDING MOTIONS AT THE TOWN OF SCITUATE ANNUAL FINANCIAL TOWN MEETING",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Amends a public law regarding the fixing of time for the election of officers in the town of Scituate by requiring prior notice and posting of motions to be made from the floor at the annual financial town meeting of the town of Scituate."
    }
  ],
