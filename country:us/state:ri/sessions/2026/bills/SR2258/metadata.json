  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Creates a 15-member joint commission to study and provide recommendations regarding safe staffing ratios in hospitals, and who would report back to the General Assembly by September 1, 2027, and expire on January 30, 2028."
    }
