  "abstracts": [
    {
      "note": "summary",
      "abstract": "Permits North Providence to require 2 parking spaces for each studio, 1 bedroom, or 2 bedroom low- or moderate-income housing unit upon the determination that limited or no local public transportation or off-street parking is available near these units."
