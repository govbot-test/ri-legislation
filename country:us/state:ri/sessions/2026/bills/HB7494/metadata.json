  "identifier": "HB7494",
  "title": "AN ACT RELATING TO ELECTIONS -- MAIL BALLOTS",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the board of elections to establish a secure area for the public observation of mail ballot processing and require the mail ballot voter\u2019s signature be compared to the signature on file within the state central voter registration system."
    }
  ],
