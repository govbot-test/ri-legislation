{
  "legislative_session": "2026",
  "identifier": "SB2403",
  "title": "AN ACT RELATING TO MOTOR AND OTHER VEHICLES -- SUSPENSION OR REVOCATION OF LICENSES",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires that the license plates of a vehicle be confiscated by a police officer if the owner was arrested for driving while their license was suspended, revoked or cancelled for refusing to submit to a chemical test or for operating under the influence."
    }
  ],
