  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires electric and gas utilities to provide a detailed breakdown of supply, delivery, and public policy costs on electric and gas bills, including specific costs for renewable energy sources, and mandate public comment and PUC approval."
