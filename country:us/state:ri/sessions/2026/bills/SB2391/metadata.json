  "identifier": "SB2391",
  "title": "AN ACT RELATING TO PROPERTY -- PUBLIC AUCTIONS OF REAL ESTATE",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires public auctions by any city or town of real estate or an interest therein to only be done in person and not by electronic or remote procedures unless authorized by court order."
    }
  ],
