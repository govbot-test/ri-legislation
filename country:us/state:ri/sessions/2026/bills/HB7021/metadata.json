  "identifier": "HB7021",
  "title": "AN ACT RELATING TO HEALTH AND SAFETY -- RETAIL ESTABLISHMENTS-VEHICLE SAFETY BARRIERS",
  "from_organization": "~{\"classification\": \"lower\"}",
