  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires commercial property owners to install vehicle barriers at their retail establishments when new construction or renovations are being done and permits insurers to consider the installation to provide a discount on the owner's insurance policy."
