  "identifier": "SB2367",
  "title": "AN ACT RELATING TO TAXATION -- FIRST-TIME HOMEBUYER SAVINGS ACCOUNT ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
