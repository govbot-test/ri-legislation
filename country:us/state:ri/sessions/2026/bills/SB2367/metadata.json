  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows an individual, who is a first-time homebuyer, to contribute funds to a first-time homebuyer savings account with Rhode Island housing to pay for eligible costs to purchase a home and receive tax deductions and exemptions."
    }
