  "identifier": "SB2268",
  "title": "AN ACT RELATING TO TOWNS AND CITIES -- LOW AND MODERATE INCOME HOUSING",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows faith-based organizations to develop affordable housing on land they own provided at least 50 % of the housing to be developed is low- or moderate-income housing and the land is owned or held in trust by the faith-based organizations."
    }
  ],
