  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires that insurance policies for property damage, personal injuries, and indemnification other than payment of compensation for workers compensation, state policy limits and no amount of the policy may be used to pay costs to defend a claim."
    }
