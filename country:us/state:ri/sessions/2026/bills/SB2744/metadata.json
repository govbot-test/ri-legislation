  "identifier": "SB2744",
  "title": "AN ACT RELATING TO LABOR AND LABOR RELATIONS -- THE RHODE ISLAND OPPORTUNITY FOR EMPLOYEE OWNERSHIP ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Establishes an opportunity for employee ownership where the owner notifies all current full-time and part-time employees and provides them with a 30-day window in which to initiate a process to potentially purchase the business as a workers' cooperative."
    }
  ],
