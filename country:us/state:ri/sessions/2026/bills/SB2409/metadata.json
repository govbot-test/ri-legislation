  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Recognizes that municipal employees have the opportunity to utilize binding arbitration and establishes new factors for the arbitrators to consider. These factors include comparisons of wages/hourly conditions of employment in similarly skilled jobs."
    }
