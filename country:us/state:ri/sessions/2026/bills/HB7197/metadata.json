  "identifier": "HB7197",
  "title": "AN ACT RELATING TO CRIMINAL OFFENSES -- GAMBLING AND LOTTERIES",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows social gaming in private residences and in public taverns or private clubs as long as the gambling is incidental to a bona fide social relationship between the participants and no person other than the participants receive anything of value."
    }
  ],
