  "identifier": "SB2099",
  "title": "AN ACT RELATING TO TAXATION -- SURPLUS FUNDS TAX CREDIT ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Mandates that any surplus state tax revenue received in any fiscal year would be refunded to the taxpayers of this state on a proportional basis in relation to the personal income tax liability incurred by the taxpayers in that fiscal year."
    }
  ],
