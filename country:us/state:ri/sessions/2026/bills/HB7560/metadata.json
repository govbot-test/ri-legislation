  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Substitutes \"housing resources commission\" with \"department of health\" for lead hazard mitigation purposes. It also makes it easier for a property owner to release funds put into an escrow account, if needed to make required repairs or improvements."
    }
