  "abstracts": [
    {
      "note": "summary",
      "abstract": "Imposes a moratorium on the issuance of new home care provider, home nursing care provider and hospice provider licenses prior to 7/1/2031, and provides for health systems planning specific to these provider licenses during the moratorium by the DOH."
    }
