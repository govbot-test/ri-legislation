  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Permits a nurse who has the appropriate knowledge, credentials and clinical competency, to provide home services foot care, which includes routine foot and nail care, as well as implementing a plan of care that includes hygiene and fingernails."
    }
