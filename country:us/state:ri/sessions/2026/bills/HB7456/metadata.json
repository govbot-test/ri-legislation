  "abstracts": [
    {
      "note": "summary",
      "abstract": "Mandates public schools (K-12) have one full-time certified social worker for every 250 students and allocates $2 million in the Fiscal Year 2025 budget for school districts and municipalities to hire additional social workers."
    }
