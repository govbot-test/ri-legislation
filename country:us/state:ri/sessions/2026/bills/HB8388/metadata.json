  "identifier": "HB8388",
  "title": "AN ACT RELATING TO MOTOR AND OTHER VEHICLES -- REGULATION OF RENTAL OF MOTORIZED BICYCLES, MOTOR SCOOTERS AND MOTORIZED TRICYCLES IN NEW SHOREHAM",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Permits the town council of the town of New Shoreham to enact an ordinance that limits a license holder from renting or leasing more than thirty-four (34) motorized bicycles, motor scooters and/or motorized tricycles."
    }
  ],
