  "identifier": "SB2959",
  "title": "AN ACT RELATING TO COURTS AND CIVIL PROCEDURE -- PROCEDURE GENERALLY -- CAUSES OF ACTION",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
