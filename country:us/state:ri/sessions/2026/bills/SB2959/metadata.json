  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Tolls the statute of limitations for causes of action arising out of business activities conducted in this state by a person or entity required to register with the secretary of state but failing to do so, until such person or entity becomes registered."
    }
