  "abstracts": [
    {
      "note": "summary",
      "abstract": "Amends the residential landlord and tenant act to prohibit the use of algorithmic renting-setting software that relies on nonpublic competitor data to determine rental prices or occupancy levels for residential dwelling units in Rhode Island."
    }
