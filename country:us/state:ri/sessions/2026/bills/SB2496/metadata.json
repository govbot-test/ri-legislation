  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows a pregnant member or member that has given birth in the past six (6) months to appear remotely and permits any member that participates in a meeting remotely to vote at that meeting, provided that the meeting is held in person."
    }
