  "abstracts": [
    {
      "note": "summary",
      "abstract": "Authorizes veterinarians to establish a client-patient relationship through electronic means, subject to limitations and requirements such as Vet making a good faith effort to determine if care should be provided through telemedicine instead of in person."
    }
