  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Provides for paid leave for a state employee who donates an organ and duration of the leave is dependent on the type of donation and notice should be provided to the employer at least thirty (30) days prior to the leave."
    }
