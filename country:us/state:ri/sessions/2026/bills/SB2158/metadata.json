  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits any questioning of a juvenile who is suspected of delinquent or criminal behavior, unless the parent of guardian of the juvenile is present, or unless an attorney is present or the juvenile and their parents have waived their presence."
