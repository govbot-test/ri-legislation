  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Authorizes the city of Providence to issue not more than $25,000,000 in general obligation bonds and notes to fund the providence housing trust fund to finance affordable multi-family housing projects in the city."
    }
  ],
