  "identifier": "SB2806",
  "title": "AN ACT RELATING TO INSURANCE -- ACCIDENT AND SICKNESS INSURANCE POLICIES -- EQUAL PAY FOR HEALTHCARE PROVIDERS",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the state and private health insurers to reimburse claims for healthcare services provided by nurse practitioners and physician assistants at the same amount as the reimbursement paid to a physician performing the service in the area served."
    }
