{
  "legislative_session": "2026",
  "identifier": "HB7030",
  "title": "AN ACT RELATING TO HEALTH AND SAFETY -- HEALTHCARE WORKER PLATFORM ACT",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Establishes the healthcare worker platform and would require platforms offering healthcare shifts to register with the department of health by June 1, 2027, while, specifically, exempting them from being classified as nursing service agencies."
    }
  ],
