  "identifier": "HB7284",
  "title": "AN ACT RELATING TO PROBATE PRACTICE AND PROCEDURE -- UNIFORM REAL PROPERTY TRANSFER ON DEATH ACT",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows an owner or owners of real property to execute a deed that names one or more beneficiaries who will obtain title to the property at the owner's death without the necessity of probate."
    }
