  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Redefines what constitutes a farm by reducing the amount of revenue from farm products required to be sold from $10,000 to $2500. It also expands the farm to include all agricultural operations, including forestry."
    }
