  "identifier": "SB2443",
  "title": "AN ACT RELATING TO AGRICULTURE AND FORESTRY -- AGRICULTURAL FUNCTIONS OF DEPARTMENT OF ENVIRONMENTAL MANAGEMENT",
  "from_organization": "~{\"classification\": \"upper\"}",
