  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Provides that a certificate be provided for every contract for the purchase and sale of real estate certifying that the property has a functioning on-site wastewater treatment system or a sewer connection and not a cesspool."
    }
