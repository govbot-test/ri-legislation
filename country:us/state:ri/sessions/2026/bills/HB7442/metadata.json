  "identifier": "HB7442",
  "title": "AN ACT RELATING TO LABOR AND LABOR RELATIONS -- INSPECTION OF PERSONNEL FILES",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Expands the obligations of employers to create, maintain and retain their employees' personnel records, it requires that records be retained for at least 3 years after employee's termination. It also increases the financial penalties for each violation."
    }
  ],
