  "identifier": "SB3022",
  "title": "AN ACT RELATING TO INSURANCE -- ACCIDENT AND SICKNESS INSURANCE POLICIES",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires insurers to develop plans for coverage and access to nonnarcotic, nonopioid and nonmedication pain management for moderate to severe pain. It further restricts utilization review for nonopioid drugs."
    }
