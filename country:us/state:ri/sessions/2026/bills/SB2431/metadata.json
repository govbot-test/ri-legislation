{
  "legislative_session": "2026",
  "identifier": "SB2431",
  "title": "AN ACT RELATING TO INSURANCE -- CASUALTY INSURANCE RATING",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Permits on and after July 1, 2027, for an insurer to consider the zip code in which the vehicle is garaged; provided that, the calculation of the zip code is segmented by the municipality where the vehicle is garaged."
    }
  ],
