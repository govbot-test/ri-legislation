  "identifier": "SB2151",
  "title": "AN ACT RELATING TO ANIMALS AND ANIMAL HUSBANDRY -- CRUELTY TO ANIMALS",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows animal control officers in the cities and towns to lawfully take charge of and provide adequate care to any animal found abandoned or neglected or hazardously accumulated and includes them as agents authorized to enforce the provisions of this law."
    }
  ],
