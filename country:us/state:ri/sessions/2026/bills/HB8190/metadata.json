  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Increase the estate exemption to $5,000,000 for January 1, 2027, $7,500,000 for January 1, 2029, $10,000,000 for January 1, 2031. This act would eliminate the estate tax for decedents whose death occurs on or after January 1, 2033."
    }
