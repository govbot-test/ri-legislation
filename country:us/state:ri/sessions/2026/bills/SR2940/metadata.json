  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Creates a 19 member special legislative study commission whose purpose it would be to study current practices of state and municipal Juvenile Hearing Boards established pursuant to \u00a7\u00a7 8-10-23.1 or 8-10-23.2."
    }
