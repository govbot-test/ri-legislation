  "identifier": "SB3088",
  "title": "AN ACT RELATING TO INSURANCE -- EQUITABLE FUNDING FOR HEALTHCARE PROVIDER BAD DEBT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Establishes a procedure for a health insurer to reimburse a healthcare provider no less than sixty-five percent (65%) of each unpaid co-payment, co-insurance or deductible amount due, after reasonable collection efforts."
    }
