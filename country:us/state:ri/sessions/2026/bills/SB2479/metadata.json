  "identifier": "SB2479",
  "title": "AN ACT RELATING TO STATE AFFAIRS AND GOVERNMENT -- LAW ENFORCEMENT OFFICERS' DUE PROCESS, ACCOUNTABILITY AND TRANSPARENCY ACT -- ICE OUT ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits law enforcement agencies from hiring individuals who were hired as a sworn officer of the US Immigration and Customs enforcement Agency on or after January 20, 2025, and applies prospectively to an individual hired on or after October 1, 2026."
    }
  ],
