{
  "legislative_session": "2026",
  "identifier": "SB2902",
  "title": "AN ACT RELATING TO PROPERTY -- CAPACITY TO HOLD REAL ESTATE",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Precludes a legal entity from owning property whose value is over $25,000,000. If the property value exceeds $25,000,000, then the entity must divest a graduated yearly amount over the next 10 years, until value is less than $25,000,000."
    }
  ],
