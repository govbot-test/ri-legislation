  "identifier": "SB3087",
  "title": "AN ACT AUTHORIZING THE CITY OF CENTRAL FALLS TO FINANCE THE CONSTRUCTION, RENOVATION, IMPROVEMENT, ALTERATION, REPAIR, FURNISHING AND EQUIPPING OF SCHOOLS AND SCHOOL FACILITIES IN THE CITY BY THE ISSUANCE OF NOT MORE THAN $25,000,000 BONDS, NOTES AND/OR OTHER EVIDENCES OF INDEBTEDNESS THEREFOR",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Authorizes the City of Central Falls to issue bonds and notes in an amount not exceeding $25,000,000 to finance the construction, renovation, improvement, alteration, repair furnishing and equipping of schools and school facilities in the city."
    }
  ],
