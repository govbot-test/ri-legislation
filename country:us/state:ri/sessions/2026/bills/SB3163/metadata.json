  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows for the sealing of an eviction record for a defective complaint and/or lack of jurisdiction and would, upon motion of a person between 18 and 21 years of age, seal a person's association with an eviction under certain circumstances."
