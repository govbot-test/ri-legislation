  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Directs middle and high schools which issue student identification cards to include on those cards on or before September 8, 2026, contact crisis telephone numbers for suicide prevention and substance use disorder prevention."
    }
  ],
