  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Establishes the Property Equity Protection Act to protect property owners from losing their equity when their property is seized to pay a debt to the government by allowing ample time to pay off the debt and adequate notice of due process."
    }
