{
  "legislative_session": "2026",
  "identifier": "SB2232",
  "title": "AN ACT RELATING TO TAXATION -- REAL ESTATE CONVEYANCE TAX",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows a municipality to set its own conveyance tax rate for residential properties sold in excess of $900,000.00 at $10 per $500. Provides collected taxes to be in a restricted account and distributed within 2 years for affordable housing."
    }
  ],
