  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows any city, town, state and/or agency of a municipality or the state to report unpaid fines of two hundred dollars ($200) or more to the division of motor vehicles as grounds for refusal of registration."
