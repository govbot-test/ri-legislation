  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Mandates health insurance coverage for medically necessary hormonal/non-hormonal therapy to treat symptoms of peri-menopause/menopause, if therapy is recommended by qualified healthcare provider licensed in RI and has proven safe and effective."
    }
