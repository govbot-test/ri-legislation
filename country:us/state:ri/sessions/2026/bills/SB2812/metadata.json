  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires that the state\u2019s share to support public library services in fiscal year 2027 be fixed at twenty-five percent (25%) of the amount appropriated and expended by the city or town in the second preceding fiscal year."
