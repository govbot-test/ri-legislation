  "identifier": "HB8243",
  "title": "AN ACT RELATING TO COMMERCIAL LAW -- GENERAL REGULATORY PROVISIONS -- DECEPTIVE TRADE PRACTICES",
  "from_organization": "~{\"classification\": \"lower\"}",
