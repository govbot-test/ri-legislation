  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits disclosure terms \"down payment\", \"money down\", or any similar language to describe lump sum payments in order to reduce monthly lease payments. Provides that lump sum payments are non-refundable in the event of a total loss of the vehicle."
    }
