  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires individuals seeking a judicial nomination to reapply to JNC every 3 years and make those individuals selected as finalists, eligible only for the court in which they applied and were chosen during the five years following their selection."
