  "identifier": "HB7049",
  "title": "AN ACT RELATING TO ELECTIONS -- PRIMARY ELECTIONS",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires that the primary election date, statutorily the eighth Tuesday preceding the biennial state elections, shall be held on the Wednesday when Labor Day is the day before said Tuesday. No other filing deadlines would be affected."
    }
  ],
