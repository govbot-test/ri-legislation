  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Reduces the cigarette tax imposed by 75% for any modified risk tobacco product as defined in \u00a7 21 U.S.C. 387 k as a tobacco product sold/distributed to reduce the harm/risk of tobacco-related disease associated with commercially marketed tobacco products."
    }
