  "title": "AN ACT RELATING TO TAXATION -- CIGARETTE, OTHER TOBACCO PRODUCTS, AND ELECTRONIC NICOTINE-DELIVERY SYSTEM PRODUCTS",
  "from_organization": "~{\"classification\": \"upper\"}",
