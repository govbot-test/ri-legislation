  "identifier": "HB7180",
  "title": "AN ACT RELATING TO COMMERCIAL LAW--GENERAL REGULATORY PROVISIONS -- DIGITAL ELECTRONICS RIGHT TO REPAIR ACT",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Establishes a digital electronics right to repair, which allows for digital electronic equipment and parts that are sold in this state on or after January 1, 2027, to be repaired at an independent repair provider."
    }
