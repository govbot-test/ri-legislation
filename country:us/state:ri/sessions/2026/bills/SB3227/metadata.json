  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Provides that a portion of state income taxes from employees working at not-for-profit healthcare institutions, health service institutions, and educational institutions be allocated to the city of Providence."
    }
