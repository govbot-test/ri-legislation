  "abstracts": [
    {
      "note": "summary",
      "abstract": "Establishes a restricted receipt account for the benefit of the Rhode Island public transit authority funded by sales taxes collected from ride-share companies; and provided further, the account would be exempt from indirect cost recovery provisions."
