{
  "legislative_session": "2026",
  "identifier": "SB2826",
  "title": "AN ACT RELATING TO EDUCATION -- THE EDUCATION EQUITY AND PROPERTY TAX RELIEF ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Provides that in local education agencies when over 45% of the children have a family income that is at or below 185% of federal poverty guidelines, then the student success factor will be 50% by the core instruction per-pupil amount."
    }
  ],
