{
  "legislative_session": "2026",
  "identifier": "HB7374",
  "title": "AN ACT RELATING TO TOWNS AND CITIES -- ZONING ORDINANCES",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Amends the zoning ordinances to allow the town to restrict occupancy to one unrelated person per bedroom in a dwelling, up to a five (5) bedroom unit. Units with more than five (5) bedrooms may be limited to five (5) unrelated persons per unit."
    }
  ],
