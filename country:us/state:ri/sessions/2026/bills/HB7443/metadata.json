  "identifier": "HB7443",
  "title": "AN ACT RELATING TO TOWNS AND CITIES -- OPTIONAL RETIREMENT FOR MEMBERS OF POLICE FORCE AND FIREFIGHTERS",
  "from_organization": "~{\"classification\": \"lower\"}",
