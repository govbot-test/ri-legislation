  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Authorizes an annual two and one-half percent (2.5%) escalation for all active and retired police and firefighter's retirement pension allowance, compounded each year on January 1 following the year of retirement and continuing yearly, on that date."
    }
