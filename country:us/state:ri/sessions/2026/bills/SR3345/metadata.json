  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Creates a 12 member special legislative commission whose purpose it would be to make a comprehensive study of RI medical malpractice lawsuits, claims, settlements, administrative filings and impact on medical malpractice insurance costs for providers."
