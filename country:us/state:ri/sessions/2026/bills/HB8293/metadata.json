  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Permits non-sworn public safety officers/security guards at private colleges/universities to detain individuals for no longer than 30 minutes within the campus\u2019s jurisdiction if the officer or guard believes the person committed a criminal offense."
