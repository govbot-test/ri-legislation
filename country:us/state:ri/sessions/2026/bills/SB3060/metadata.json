  "identifier": "SB3060",
  "title": "AN ACT RELATING TO INSURANCE -- PHARMACY BENEFIT MANAGERS ACT",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires pharmacy benefit managers to apply for certificate of authority from the office of health insurance commissioner to operate such a business in this state and empowers the commissioner to oversee pharmacy benefit managers and penalize violations."
    }
  ],
